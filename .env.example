# =============================================================================
# 毕设选题指导系统 — 环境变量模板
# 复制此文件为 .env 并填入真实值后启动项目
# =============================================================================

# Flask 配置
SECRET_KEY=your-secret-key-change-me
FLASK_ENV=development

# SQLite 数据库路径（默认使用 instance/app.db）
# DATABASE_URI=sqlite:///instance/app.db

# 上传与解析目录（默认使用绝对路径，无需修改）
# UPLOAD_FOLDER=app/uploads/raw
# PARSED_FOLDER=app/uploads/parsed

# ChromaDB 向量数据库（默认使用绝对路径）
# CHROMA_DIR=app/data/chroma_db

# ---------------------------------------------------------------------------
# 智谱 AI 大模型 & Embedding 配置
# 注册地址：https://open.bigmodel.cn
# ---------------------------------------------------------------------------

# Embedding 模型名称（智谱可选：embedding-3、embedding-2）
EMBEDDING_MODEL=embedding-3

# Chat 模型名称（智谱可选：glm-4-flash、glm-4-plus 等）
LLM_MODEL=glm-4-flash

# API Base URL（Embedding 与 Chat 共用同一入口）
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# API Key —— 请替换为你自己的智谱 API Key
LLM_API_KEY=your_zhipu_api_key_here

# 请求超时（秒）
LLM_TIMEOUT=60

# ---------------------------------------------------------------------------
# 文本分块参数
# ---------------------------------------------------------------------------
CHUNK_SIZE=500
CHUNK_OVERLAP=80
TOP_K=5

# 上传文件大小限制（字节）
MAX_CONTENT_LENGTH=20971520

# ---------------------------------------------------------------------------
# 默认演示账号（4 类固定角色）
# ---------------------------------------------------------------------------
DEFAULT_STUDENT_USERNAME=student
DEFAULT_STUDENT_PASSWORD=Stu@123
DEFAULT_TOPIC_ADMIN_USERNAME=topic_admin
DEFAULT_TOPIC_ADMIN_PASSWORD=TopicAdmin@123
DEFAULT_ACADEMIC_ADMIN_USERNAME=academic_admin
DEFAULT_ACADEMIC_ADMIN_PASSWORD=AcadAdmin@123
DEFAULT_AUDIT_ADMIN_USERNAME=audit_admin
DEFAULT_AUDIT_ADMIN_PASSWORD=Audit@123
